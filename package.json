{
  "name": "cyon-backend",
  "version": "1.0.0",
  "description": "CYON Jalingo Diocese Backend API",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "backend-dev": "nodemon backend/server.js",
    "frontend-dev": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run backend-dev\" \"npm run frontend-dev\"",
    "build": "npm install --build-from-source && npm install --prefix frontend && npm run build --prefix frontend",
    "start": "node backend/server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
