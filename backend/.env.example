# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/cyon
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cyon?retryWrites=true&w=majority

# Server Port
PORT=5000

# JWT Secret (change this in production!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Environment
NODE_ENV=development
